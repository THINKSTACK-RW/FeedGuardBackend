# FeedGuard Backend Environment Configuration

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=feedguard
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_DIALECT=postgres

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=24h

# Server Configuration
PORT=3000
NODE_ENV=development

# Africa's Talking SMS Configuration
AT_API_KEY=your_africastalking_api_key_here
AT_USERNAME=your_africastalking_username

# Sender ID Configuration
# DEVELOPMENT: Comment out both (use default sender)
# PRODUCTION: Uncomment AT_SENDER_ID for custom sender
# AT_SENDER_ID=FEEDGUARD
# SMS_NUMBER=+250788123456

# Development Configuration (use default sender)
# AT_SENDER_ID=
# SMS_NUMBER=

# Production Configuration (use custom sender)
# AT_SENDER_ID=FEEDGUARD
# SMS_NUMBER=
